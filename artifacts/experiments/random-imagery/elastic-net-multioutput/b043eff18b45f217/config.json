{
  "artifacts": {
    "overwrite": false,
    "root": "artifacts/experiments/random-imagery",
    "schema_version": 3
  },
  "bootstrap_iterations": 2000,
  "cross_validation": {
    "n_splits": 5,
    "random_state": 42,
    "scoring": "balanced_accuracy",
    "shuffle": true
  },
  "dataset": {
    "dataset_dir": "data/Data_Pattern",
    "feature_config_path": "confs/features/default.yaml",
    "image_columns": 6,
    "image_rows": 6,
    "pattern_type": "random",
    "recording_family": "patt"
  },
  "feature_screening": {
    "candidates": [
      [
        "time"
      ],
      [
        "spectral"
      ],
      [
        "time",
        "spectral"
      ],
      [
        "covariance"
      ],
      [
        "correlation"
      ],
      [
        "log_covariance"
      ],
      [
        "lndp"
      ],
      [
        "lgp"
      ],
      [
        "lbp"
      ]
    ],
    "select_k": 100,
    "variance_threshold": 0.0
  },
  "grid_search": {
    "alpha_values": [
      0.001,
      0.01,
      0.1,
      1.0
    ],
    "error_score": "raise",
    "estimator_family": "elastic_net",
    "l1_ratios": [
      0.1,
      0.5,
      0.9,
      1.0
    ],
    "max_iter": 1000000,
    "n_jobs": -1,
    "screening_alpha": 0.01,
    "screening_l1_ratio": 0.5,
    "select_k": [
      25,
      50,
      100,
      250
    ],
    "selection": "cyclic",
    "tolerance": 0.001
  },
  "model_id": "elastic-net-multioutput",
  "prediction_threshold": 0.5,
  "random_state": 42,
  "split": {
    "group_by": "subject",
    "random_state": 42,
    "require_both_classes": true,
    "test_size": 0.2
  }
}
