{
  "artifacts": {
    "overwrite": false,
    "root": "artifacts/experiments/logistic-regression",
    "schema_version": 2
  },
  "bootstrap_iterations": 2000,
  "cross_validation": {
    "n_splits": 5,
    "random_state": 42,
    "scoring": "balanced_accuracy",
    "shuffle": true
  },
  "dataset": {
    "dataset_dir": "data/Data_Pattern",
    "feature_config_path": "confs/features/default.yaml",
    "image_columns": 6,
    "image_rows": 6,
    "pattern_type": "random",
    "recording_family": "patt"
  },
  "feature_screening": {
    "c": 1.0,
    "candidates": [
      [
        "time"
      ],
      [
        "spectral"
      ],
      [
        "time",
        "spectral"
      ],
      [
        "covariance"
      ],
      [
        "correlation"
      ],
      [
        "log_covariance"
      ],
      [
        "lndp"
      ],
      [
        "lgp"
      ],
      [
        "lbp"
      ]
    ],
    "class_weight": "balanced",
    "max_iter": 5000,
    "penalty": "l2",
    "select_k": 100,
    "solver": "liblinear",
    "variance_threshold": 0.0
  },
  "grid_search": {
    "c_values": [
      0.01,
      0.1,
      1.0,
      10.0
    ],
    "class_weights": [
      null,
      "balanced"
    ],
    "error_score": "raise",
    "max_iter": 5000,
    "n_jobs": -1,
    "penalties": [
      "l1",
      "l2"
    ],
    "select_k": [
      25,
      50,
      100,
      250
    ],
    "solver": "liblinear"
  },
  "prediction_threshold": 0.5,
  "random_state": 42,
  "split": {
    "group_by": "subject",
    "random_state": 42,
    "require_both_classes": true,
    "test_size": 0.2
  }
}
